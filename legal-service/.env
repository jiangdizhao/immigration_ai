# App identity
APP_NAME=Immigration Legal Service
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8001
APP_ENV=development
API_V1_PREFIX=/api/v1
#DEBUG=true

# Host and port
#HOST=127.0.0.1
#PORT=8000

#Database
DATABASE_URL=postgresql+psycopg://rico_local:1225@localhost:5432/immigration_legal

#Auto create schema
AUTO_CREATE_SCHEMA=true

#Vector dimension
#EMBEDDING_DIMENSION=16

#Retrieval defaults
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_DISTANCE=cosine
EMBEDDING_BATCH_SIZE=64
DEFAULT_TOP_K=5
DEFAULT_TOP_K=5

#Optional backend API key
LEGAL_SERVICE_API_KEY=dev-legal-key


CANONICAL_JURISDICTION=Cth
ALLOWED_ORIGINS=http://localhost:3000

GENERAL_QA_MODEL=gpt-5.4-mini
REASONING_MODEL=gpt-5.4-mini
REASONING_MAX_CONTEXT_CHUNKS=6
REASONING_MAX_QUOTE_CHARS=400
REASONING_MAX_SUPPORTED_FACTS=8

#CORS
#CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

#Logging
#LOG_LEVEL=INFO